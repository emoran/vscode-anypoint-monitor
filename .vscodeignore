# Source files - only include compiled output
src/**
!src/resources/**
**/*.ts
!out/**/*.d.ts

# Build artifacts
**/*.map
.vscode-test/**
.vscode-test.mjs
out/test/**

# Development files
.vscode/**
.vscode-test*
.sfdx/**
.gitignore
.git/**
.gitattributes
**/tsconfig.json
**/tsconfig.base.json
contributing.md
.travis.yml
.eslintrc*
eslint.config.*
AGENTS.md
CLAUDE.md
COMMAND_CENTER_ISSUES.md
DATAWEAVE_*.md
DEPLOYMENT.md
TESTING_*.md
tmp-metrics.html
vsc-extension-quickstart.md
vss-extension.json
scripts/**

# IDE and environment files
.claude/**
.expo/**
.venv/**
.env*
*.code-workspace

# Test files
**/test/**
**/*.test.js
**/*.spec.js

# Documentation (keep only what's needed)
.github/**
docs/**

# Exclude package manager files
**/package-lock.json
**/yarn.lock
**/.yarn/**

# Never ship local credentials
config/**

# Miscellaneous
*.vsix
**/.DS_Store
**/.editorconfig
**/.eslintcache
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
