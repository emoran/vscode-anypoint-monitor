{
  "name": "anypoint-monitor",
  "displayName": "Anypoint Monitor",
  "description": "CloudHub 1.0/2.0 monitoring and multi-account management for MuleSoft. Real-time logs, API management, application diagrams, and DataWeave playground - all in VS Code.",
  "publisher": "EdgarMoran",
  "version": "0.0.76",
  "engines": {
    "vscode": "^1.96.0"
  },
  "license": "MIT",
  "author": {
    "name": "Edgar Moran",
    "email": "yucel.moran@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emoran/vscode-anypoint-monitor.git"
  },
  "bugs": {
    "url": "https://github.com/emoran/vscode-anypoint-monitor/issues"
  },
  "homepage": "https://github.com/emoran/vscode-anypoint-monitor#readme",
  "icon": "logo.png",
  "galleryBanner": {
    "color": "#214866",
    "theme": "dark"
  },
  "screenshots": [
    {
      "path": "screenshots/Screenshot1.png"
    },
    {
      "path": "screenshots/Screenshot2.png"
    },
    {
      "path": "screenshots/Screenshot3.png"
    },
    {
      "path": "screenshots/Screenshot4.png"
    },
    {
      "path": "screenshots/Screenshot5.png"
    }
  ],
  "keywords": [
    "mulesoft",
    "anypoint",
    "cloudhub",
    "api-monitoring",
    "dataweave",
    "anypoint-platform",
    "cloudhub-2.0",
    "api-management",
    "mule-runtime",
    "monitoring",
    "observability",
    "real-time-logs",
    "integration",
    "devops",
    "mulesoft-monitoring",
    "enterprise-integration",
    "ipaas",
    "deployment",
    "api-governance",
    "mulesoft-devops"
  ],
  "categories": [
    "Debuggers",
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onView:anypointCommandPalette",
    "onCommand:anypoint-monitor.userInfo",
    "onCommand:anypoint-monitor.organizationInfo",
    "onCommand:anypoint-monitor.login",
    "onCommand:anypoint-monitor.cloudhub2Apps",
    "onCommand:anypoint-monitor.cloudhub1Apps",
    "onCommand:anypoint-monitor.subscriptionExpiration",
    "onCommand:anypoint-monitor.developerUtilities",
    "onCommand:anypoint-monitor.retrieveAccessToken",
    "onCommand:anypoint-monitor.retrieveAPIManagerAPIs",
    "onCommand:anypoint-monitor.communityEvents",
    "onCommand:anypoint-monitor.provideFeedback",
    "onCommand:anypoint-monitor.logout",
    "onCommand:anypoint-monitor.auditAPIs",
    "onCommand:anypoint-monitor.realTimeLogs",
    "onCommand:anypoint-monitor.environmentComparison",
    "onCommand:anypoint-monitor.applicationDiagram",
    "onCommand:anypoint-monitor.dataweavePlayground",
    "onCommand:anypoint-monitor.accountManager",
    "onCommand:anypoint-monitor.selectBusinessGroup",
    "onCommand:anypoint-monitor.deleteAllAccounts",
    "onCommand:anypoint-monitor.migrateLegacyAccount",
    "onCommand:anypoint-monitor.applicationCommandCenter",
    "onCommand:anypoint-monitor.multiAppDashboard",
    "onCommand:anypoint-monitor.hybridApps",
    "onCommand:anypoint-monitor.hybridServers",
    "onCommand:anypoint-monitor.hybridServerGroups",
    "onCommand:anypoint-monitor.hybridClusters",
    "onCommand:anypoint-monitor.mqStats",
    "onCommand:anypoint-monitor.alertingHub",
    "onCommand:anypoint-monitor.dependencyVisualizer",
    "onCommand:anypoint-monitor.costOptimizer",
    "onCommand:anypoint-monitor.startWarRoom"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "anypoint-monitor.userInfo",
        "title": "AM: My Information"
      },
      {
        "command": "anypoint-monitor.organizationInfo",
        "title": "AM: Organization Details"
      },
      {
        "command": "anypoint-monitor.login",
        "title": "AM: Login into Anypoint Platform"
      },
      {
        "command": "anypoint-monitor.cloudhub2Apps",
        "title": "AM: Show Cloudhub 2.0 Applications"
      },
      {
        "command": "anypoint-monitor.cloudhub1Apps",
        "title": "AM: Show Cloudhub 1.0 Applications"
      },
      {
        "command": "anypoint-monitor.subscriptionExpiration",
        "title": "AM: Subscription Expiration"
      },
      {
        "command": "anypoint-monitor.developerUtilities",
        "title": "AM: Developer Utilities"
      },
      {
        "command": "anypoint-monitor.retrieveAccessToken",
        "title": "AM: Retrieve Access Token"
      },
      {
        "command": "anypoint-monitor.retrieveAPIManagerAPIs",
        "title": "AM: Retrieve API Manager APIs"
      },
      {
        "command": "anypoint-monitor.communityEvents",
        "title": "AM: MuleSoft Community Events"
      },
      {
        "command": "anypoint-monitor.provideFeedback",
        "title": "AM: Provide Feedback"
      },
      {
        "command": "anypoint-monitor.logout",
        "title": "AM: Logout"
      },
      {
        "command": "anypoint-monitor.auditAPIs",
        "title": "AM: Audit APIs"
      },
      {
        "command": "anypoint-monitor.realTimeLogs",
        "title": "AM: Real-Time Logs"
      },
      {
        "command": "anypoint-monitor.environmentComparison",
        "title": "AM: Environment Comparison Table"
      },
      {
        "command": "anypoint-monitor.applicationDiagram",
        "title": "AM: Application Diagram"
      },
      {
        "command": "anypoint-monitor.dataweavePlayground",
        "title": "AM: DataWeave Playground"
      },
      {
        "command": "anypoint-monitor.accountManager",
        "title": "AM: Account Manager"
      },
      {
        "command": "anypoint-monitor.selectBusinessGroup",
        "title": "AM: Select Business Group"
      },
      {
        "command": "anypoint-monitor.deleteAllAccounts",
        "title": "AM: Delete All Accounts & Data"
      },
      {
        "command": "anypoint-monitor.migrateLegacyAccount",
        "title": "AM: Migrate Legacy Account to Multi-Account"
      },
      {
        "command": "anypoint-monitor.applicationCommandCenter",
        "title": "AM: Application Command Center"
      },
      {
        "command": "anypoint-monitor.multiAppDashboard",
        "title": "AM: Multi-App Overview Dashboard"
      },
      {
        "command": "anypoint-monitor.hybridApps",
        "title": "AM: Show Hybrid Applications"
      },
      {
        "command": "anypoint-monitor.hybridServers",
        "title": "AM: Show Hybrid Servers"
      },
      {
        "command": "anypoint-monitor.hybridServerGroups",
        "title": "AM: Show Hybrid Server Groups"
      },
      {
        "command": "anypoint-monitor.hybridClusters",
        "title": "AM: Show Hybrid Clusters"
      },
      {
        "command": "anypoint-monitor.mqStats",
        "title": "AM: AnypointMQ Statistics"
      },
      {
        "command": "anypoint-monitor.alertingHub",
        "title": "AM: Alerting Hub"
      },
      {
        "command": "anypoint-monitor.dependencyVisualizer",
        "title": "AM: Live Connection Tracer"
      },
      {
        "command": "anypoint-monitor.costOptimizer",
        "title": "AM: Cost Optimizer"
      },
      {
        "command": "anypoint-monitor.refreshCommandPalette",
        "title": "AM: Refresh Command Palette",
        "icon": "$(refresh)"
      },
      {
        "command": "anypoint-monitor.startWarRoom",
        "title": "AM: Start War Room"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "anypoint-monitor",
          "title": "Anypoint Monitor",
          "icon": "logo-mono.svg"
        }
      ]
    },
    "views": {
      "anypoint-monitor": [
        {
          "id": "anypointCommandPalette",
          "name": "Commands",
          "icon": "logo-mono.svg",
          "contextualTitle": "Anypoint Monitor"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "anypointCommandPalette",
        "contents": "Welcome to Anypoint Monitor.\n\nConnect to your Anypoint Platform to monitor applications, manage APIs, stream logs, and more.\n[Connect Account](command:anypoint-monitor.login)\nManage multiple organizations from one place.\n[Account Manager](command:anypoint-monitor.accountManager)\n[Learn More](https://github.com/emoran/vscode-anypoint-monitor)",
        "when": "!anypoint-monitor.hasAccount"
      }
    ],
    "walkthroughs": [
      {
        "id": "anypoint-monitor.gettingStarted",
        "title": "Get Started with Anypoint Monitor",
        "description": "Connect to your Anypoint Platform and start monitoring your applications directly from VS Code.",
        "steps": [
          {
            "id": "connect",
            "title": "Connect Your Anypoint Account",
            "description": "Authenticate with OAuth 2.0 to securely connect your Anypoint Platform account.\n[Connect Account](command:anypoint-monitor.login)",
            "media": {
              "markdown": "walkthroughs/connect.md"
            },
            "completionEvents": [
              "onCommand:anypoint-monitor.login"
            ]
          },
          {
            "id": "viewApps",
            "title": "View Your Applications",
            "description": "See all CloudHub 1.0/2.0 and Hybrid apps with health scores and metrics at a glance.\n[Open Multi-App Dashboard](command:anypoint-monitor.multiAppDashboard)",
            "media": {
              "markdown": "walkthroughs/view-apps.md"
            },
            "completionEvents": [
              "onCommand:anypoint-monitor.multiAppDashboard"
            ]
          },
          {
            "id": "streamLogs",
            "title": "Stream Real-Time Logs",
            "description": "Tail application logs live with filtering by level, content, and thread. Export in JSON, CSV, or TXT.\n[Open Real-Time Logs](command:anypoint-monitor.realTimeLogs)",
            "media": {
              "markdown": "walkthroughs/stream-logs.md"
            },
            "completionEvents": [
              "onCommand:anypoint-monitor.realTimeLogs"
            ]
          },
          {
            "id": "commandCenter",
            "title": "Explore the Command Center",
            "description": "Deep dive into a single application with KPIs, AI insights, performance metrics, and lifecycle management.\n[Open Command Center](command:anypoint-monitor.applicationCommandCenter)",
            "media": {
              "markdown": "walkthroughs/command-center.md"
            },
            "completionEvents": [
              "onCommand:anypoint-monitor.applicationCommandCenter"
            ]
          },
          {
            "id": "warRoom",
            "title": "Run an Incident War Room",
            "description": "Automated production incident triage: select seed apps, auto-expand blast radius, correlate events, and get a probable root cause.\n[Start War Room](command:anypoint-monitor.startWarRoom)",
            "media": {
              "markdown": "walkthroughs/war-room.md"
            },
            "completionEvents": [
              "onCommand:anypoint-monitor.startWarRoom"
            ]
          }
        ]
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "anypoint-monitor.refreshCommandPalette",
          "when": "view == anypointCommandPalette",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "anypoint-monitor.startWarRoom",
        "key": "ctrl+shift+w",
        "mac": "cmd+shift+w"
      },
      {
        "command": "anypoint-monitor.alertingHub",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      }
    ],
    "configuration": {
      "title": "Anypoint Monitor",
      "properties": {
        "anypointMonitor.gov.clientId": {
          "type": "string",
          "default": "",
          "description": "Client ID for Anypoint Platform GOV region Connected App. Required for logging into GOV (GovCloud) region."
        },
        "anypointMonitor.gov.clientSecret": {
          "type": "string",
          "default": "",
          "description": "Client Secret for Anypoint Platform GOV region Connected App. Required for logging into GOV (GovCloud) region."
        },
        "anypointMonitor.telemetry.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable telemetry for Anypoint Monitor. Also respects VS Code telemetry settings."
        },
        "anypointMonitor.telemetry.connectionString": {
          "type": "string",
          "default": "",
          "description": "Azure Application Insights connection string for extension telemetry."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run telemetry:inject && npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "deploy": "vsce publish",
    "telemetry:inject": "node scripts/inject-telemetry.js",
    "telemetry:clear": "node scripts/clear-telemetry.js"
  },
  "devDependencies": {
    "@types/applicationinsights": "^0.20.0",
    "@types/jszip": "^3.4.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.16.0",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "applicationinsights": "^3.13.0",
    "axios": "^1.7.9",
    "jszip": "^3.10.1",
    "open": "^10.1.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.4",
    "diff": "^8.0.3"
  }
}
